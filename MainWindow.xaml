<Window x:Class="SystemOptimierer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="System Optimierer &amp; Updater PRO" Height="900" Width="1050" MinHeight="750" MinWidth="900"
        Background="Transparent" FontFamily="Segoe UI" Icon="icon.ico" WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <!-- ===================== BUTTONS ===================== -->
        <Style TargetType="Button" x:Key="ModernButtonStyle">
            <Setter Property="Background"       Value="#1A1C23"/>
            <Setter Property="Foreground"       Value="#E2E2E2"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="Padding"          Value="18,9"/>
            <Setter Property="Margin"           Value="0,0,10,0"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="BorderBrush"      Value="#2A2D35"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"   Value="#2D72D9"/>
                                <Setter TargetName="border" Property="BorderBrush"  Value="#3D82E9"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background"  Value="#1E5BB5"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background"  Value="#1A1A1A"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#1A1A1A"/>
                                <Setter Property="Foreground" Value="#444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="DangerButtonStyle" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Foreground"  Value="#FF6B6B"/>
            <Setter Property="BorderBrush" Value="#4A1C1C"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background"  Value="#C62828"/>
                    <Setter Property="BorderBrush" Value="#E53935"/>
                    <Setter Property="Foreground"  Value="White"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#B71C1C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TITLE BAR BUTTONS -->
        <Style TargetType="Button" x:Key="TitleBarButtonStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8A8D93"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Width" Value="45"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2D2F36"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#3A3D45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="TitleBarCloseButtonStyle" BasedOn="{StaticResource TitleBarButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#F1707A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ===================== NAV ITEMS ===================== -->
        <Style TargetType="RadioButton" x:Key="NavItemStyle">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#9EA3B0"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="Medium"/>
            <Setter Property="Padding"         Value="14,12"/>
            <Setter Property="Margin"          Value="0,2,0,2"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="GroupName"       Value="NavGroup"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bg" Background="Transparent" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="icon" Text="{TemplateBinding Tag}" FontSize="16"
                                           VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{TemplateBinding Foreground}"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#1E2028"/>
                                <Setter Property="Foreground" Value="#C8CBCF"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#1A2A4A"/>
                                <Setter Property="Foreground" Value="#4D9EFF"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===================== CARDS ===================== -->
        <Style TargetType="Border" x:Key="CardStyle">
            <Setter Property="Background"      Value="#1A1C23"/>
            <Setter Property="BorderBrush"     Value="#22252D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="10"/>
            <Setter Property="Padding"         Value="22,18"/>
            <Setter Property="Margin"          Value="0,0,0,14"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="12" Opacity="0.25" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===================== TYPOGRAPHY ===================== -->
        <Style TargetType="TextBlock" x:Key="CardTitle">
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="FontSize"    Value="15"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Margin"      Value="0,0,0,5"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="CardDesc">
            <Setter Property="Foreground"    Value="#808590"/>
            <Setter Property="FontSize"      Value="12"/>
            <Setter Property="Margin"        Value="0,0,0,14"/>
            <Setter Property="TextWrapping"  Value="Wrap"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="SectionHeader">
            <Setter Property="Foreground"  Value="#4D9EFF"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Margin"      Value="0,0,0,10"/>
        </Style>

        <!-- ===================== GLOBAL SCROLLBAR STYLE ===================== -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#121212"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Bg" SnapsToDevicePixels="true" Background="#121212">
                            <Track x:Name="PART_Track" IsDirectionReversed="true" Grid.Row="0">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="false"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" Margin="1,0,1,0">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#3A3D4A" CornerRadius="4"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="false"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Width" Value="Auto"/>
                                <Setter Property="Height" Value="8"/>
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,1,0,1"/>
                                <Setter TargetName="Thumb" Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="#3A3D4A" CornerRadius="4"/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===================== SCROLLBAR ===================== -->
        <Style TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar" Grid.Column="1"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===================== PREMIUM PROGRESSBAR ===================== -->
        <Style x:Key="PremiumProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="6"/>
            <Setter Property="Background" Value="#15171E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="TemplateRoot" SnapsToDevicePixels="true">
                            <!-- Background Track -->
                            <Border Background="{TemplateBinding Background}" CornerRadius="3" BorderThickness="0"/>
                            
                            <!-- Glowing Track (behind the indicator for back glow) -->
                            <Border x:Name="GlowTrack" Background="Transparent" CornerRadius="3" Opacity="0.5"/>

                            <!-- Standard Indicator (determinate) -->
                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left" Background="#2D72D9" CornerRadius="3">
                                <Border.Effect>
                                    <DropShadowEffect Color="#2D72D9" BlurRadius="6" ShadowDepth="0" Opacity="0.7"/>
                                </Border.Effect>
                            </Border>

                            <!-- Glow effect container for Indeterminate state -->
                            <Grid x:Name="AnimationVisuals" ClipToBounds="True" Visibility="Collapsed">
                                <Border x:Name="GlowIndicator" CornerRadius="3" Width="150" HorizontalAlignment="Left">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#2D72D9" Offset="0"/>
                                            <GradientStop Color="#63A1FF" Offset="0.5"/>
                                            <GradientStop Color="#2D72D9" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect Color="#2D72D9" BlurRadius="10" ShadowDepth="0" Opacity="0.9"/>
                                    </Border.Effect>
                                    <Border.RenderTransform>
                                        <TranslateTransform X="-150"/>
                                    </Border.RenderTransform>
                                </Border>
                            </Grid>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsIndeterminate" Value="True">
                                <Setter TargetName="PART_Indicator" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="AnimationVisuals" Property="Visibility" Value="Visible"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard x:Name="IndeterminateAnimation">
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="GlowIndicator"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                             From="-150" To="850" Duration="0:0:1.8">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="GlowIndicator"
                                                             Storyboard.TargetProperty="Opacity"
                                                             From="0.7" To="1.0" Duration="0:0:0.9"
                                                             AutoReverse="True" RepeatBehavior="Forever"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="IndeterminateAnimation"/>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===================== SEARCH TEXTBOX ===================== -->
        <Style TargetType="TextBox" x:Key="ModernTextBoxStyle">
            <Setter Property="Background" Value="#1A1C23"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2A2D35"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#4D9EFF"/>
            <Setter Property="SelectionBrush" Value="#2D72D9"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <Grid VerticalAlignment="Center">
                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                                <TextBlock x:Name="placeholder" Text="{TemplateBinding Tag}"
                                           Foreground="#555A67" Margin="14,10"
                                           IsHitTestVisible="False" VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="placeholder" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#4D9EFF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#3D414E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===================== COMBOBOX ===================== -->
        <Style x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="templateRoot" 
                                Background="#1A1C23" 
                                BorderBrush="#242731" 
                                BorderThickness="1" 
                                CornerRadius="4"
                                SnapsToDevicePixels="true">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>
                                <!-- Arrow -->
                                <Path x:Name="arrow" 
                                      Grid.Column="1"
                                      Data="M 0 0 L 4 4 L 8 0 Z" 
                                      Fill="#C2C5CC" 
                                      HorizontalAlignment="Center" 
                                      VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="templateRoot" Property="Background" Value="#242731"/>
                                <Setter TargetName="templateRoot" Property="BorderBrush" Value="#3D414E"/>
                                <Setter TargetName="arrow" Property="Fill" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="true">
                                <Setter TargetName="templateRoot" Property="Background" Value="#111218"/>
                                <Setter TargetName="templateRoot" Property="BorderBrush" Value="#2D72D9"/>
                                <Setter TargetName="arrow" Property="Fill" Value="#4D9EFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="templateRoot" Property="Background" Value="#15171E"/>
                                <Setter TargetName="templateRoot" Property="BorderBrush" Value="#1A1C23"/>
                                <Setter TargetName="arrow" Property="Fill" Value="#444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PremiumComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#1A1C23"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#242731"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#111218"/>
                        <Setter Property="Foreground" Value="#C2C5CC"/>
                        <Setter Property="Padding" Value="12,8"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Gd" 
                                            Background="{TemplateBinding Background}" 
                                            BorderThickness="{TemplateBinding BorderThickness}" 
                                            Padding="{TemplateBinding Padding}"
                                            SnapsToDevicePixels="true">
                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="true">
                                            <Setter TargetName="Gd" Property="Background" Value="#2D72D9"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="true">
                                            <Setter TargetName="Gd" Property="Background" Value="#1B4E9B"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="false">
                                            <Setter Property="Foreground" Value="#555"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="templateRoot" SnapsToDevicePixels="true">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="0" MaxWidth="0"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Toggle Button serving as background and drop-down indicator -->
                            <ToggleButton x:Name="toggleButton" 
                                          Grid.ColumnSpan="2" 
                                          Style="{StaticResource ComboBoxToggleButton}"
                                          Focusable="false"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                            
                            <!-- Display Area of the selected item -->
                            <ContentPresenter x:Name="contentPresenter"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              IsHitTestVisible="false"/>
                            
                            <!-- Popup showing the dropdown items -->
                            <Popup x:Name="PART_Popup"
                                   Grid.ColumnSpan="2"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom"
                                   PopupAnimation="{DynamicResource {x:Static SystemParameters.ComboBoxPopupAnimationKey}}">
                                <Border x:Name="dropDownBorder"
                                        Background="#111218"
                                        BorderBrush="#242731"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        MinWidth="{Binding ActualWidth, ElementName=templateRoot}"
                                        Margin="0,2,0,0">
                                    <ScrollViewer x:Name="dropDownScrollViewer" SnapsToDevicePixels="true">
                                        <Grid x:Name="grid" RenderOptions.ClearTypeHint="Enabled">
                                            <Canvas x:Name="canvas" HorizontalAlignment="Left" Height="0" VerticalAlignment="Top" Width="0">
                                                <Rectangle x:Name="opaqueRect" 
                                                           Fill="{Binding Background, ElementName=dropDownBorder}" 
                                                           Height="{Binding ActualHeight, ElementName=dropDownBorder}" 
                                                           Width="{Binding ActualWidth, ElementName=dropDownBorder}"/>
                                            </Canvas>
                                            <ItemsPresenter x:Name="ItemsPresenter" 
                                                            KeyboardNavigation.DirectionalNavigation="Contained" 
                                                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                        </Grid>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="false">
                                <Setter TargetName="dropDownBorder" Property="Height" Value="95"/>
                            </Trigger>
                            <Trigger Property="IsGrouping" Value="true">
                                <Setter Property="ScrollViewer.CanContentScroll" Value="false"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===================== RECOVERY ACCENTS ===================== -->
        <Style TargetType="Border" x:Key="RecoveryCardStyle">
            <Setter Property="Background" Value="#0A0B0E"/>
            <Setter Property="BorderBrush" Value="#007ACC"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#007ACC" BlurRadius="12" Opacity="0.45" ShadowDepth="0"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox" x:Key="HeaderCheckBoxStyle">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <BulletDecorator Background="Transparent">
                            <BulletDecorator.Bullet>
                                <Border x:Name="border" Width="20" Height="20"
                                        Background="#262930" BorderBrush="#808590"
                                        BorderThickness="1.5" CornerRadius="4"
                                        VerticalAlignment="Center">
                                    <Grid>
                                        <TextBlock x:Name="checkMark" Text="✓"
                                                   Foreground="White" FontSize="14"
                                                   FontWeight="Bold" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" Visibility="Collapsed"/>
                                    </Grid>
                                </Border>
                            </BulletDecorator.Bullet>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </BulletDecorator>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="White"/>
                                <Setter TargetName="border" Property="Background" Value="#3D424F"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===================== CHECKBOX ===================== -->
        <Style TargetType="CheckBox" x:Key="PremiumCheckBoxStyle">
            <Setter Property="Foreground" Value="#C8CBCF"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <BulletDecorator Background="Transparent">
                            <BulletDecorator.Bullet>
                                <Border x:Name="border" Width="18" Height="18"
                                        Background="#1A1C23" BorderBrush="#2A2D35"
                                        BorderThickness="1" CornerRadius="4"
                                        VerticalAlignment="Center">
                                    <Grid>
                                        <TextBlock x:Name="checkMark" Text="✓"
                                                   Foreground="#2D72D9" FontSize="12"
                                                   FontWeight="Bold" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" Visibility="Collapsed">
                                            <TextBlock.Effect>
                                                <DropShadowEffect Color="#2D72D9" BlurRadius="6" ShadowDepth="0" Opacity="0.8"/>
                                            </TextBlock.Effect>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </BulletDecorator.Bullet>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </BulletDecorator>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#2D72D9"/>
                                <Setter TargetName="border" Property="Background" Value="#1A2233"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#2D72D9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===================== RADIOBUTTON ===================== -->
        <Style TargetType="RadioButton" x:Key="PremiumRadioButtonStyle">
            <Setter Property="Foreground" Value="#C8CBCF"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <BulletDecorator Background="Transparent">
                            <BulletDecorator.Bullet>
                                <Border x:Name="border" Width="18" Height="18"
                                        Background="#1A1C23" BorderBrush="#2A2D35"
                                        BorderThickness="1" CornerRadius="9"
                                        VerticalAlignment="Center">
                                    <Grid>
                                        <Ellipse x:Name="dot" Width="8" Height="8"
                                                 Fill="#2D72D9" Visibility="Collapsed">
                                            <Ellipse.Effect>
                                                <DropShadowEffect Color="#2D72D9" BlurRadius="6" ShadowDepth="0" Opacity="0.8"/>
                                            </Ellipse.Effect>
                                        </Ellipse>
                                    </Grid>
                                </Border>
                            </BulletDecorator.Bullet>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </BulletDecorator>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="dot" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#2D72D9"/>
                                <Setter TargetName="border" Property="Background" Value="#1A2233"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#2D72D9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===================== DATAGRID ===================== -->
        <Style TargetType="DataGrid" x:Key="PremiumDataGridStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="RowBackground" Value="#1A1C23"/>
            <Setter Property="AlternatingRowBackground" Value="#16171E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#242731"/>
            <Setter Property="Foreground" Value="#E2E2E2"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#242731"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="RowHeight" Value="40"/>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="12,8"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Foreground" Value="#E2E2E2"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="RowStyle">
                <Setter.Value>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Margin" Value="0,1,0,1"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#242731"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#2D72D9"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#1A1C23"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Padding" Value="12,8"/>
                        <Setter Property="BorderThickness" Value="0,0,0,2"/>
                        <Setter Property="BorderBrush" Value="#2D72D9"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridColumnHeader">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#242731"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Premium Dark-Themed TabControl & TabItem Styles -->
        <Style TargetType="TabControl" x:Key="PremiumTabControlStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style TargetType="TabItem" x:Key="PremiumTabItemStyle">
            <Setter Property="Foreground" Value="#707584"/>
            <Setter Property="Background" Value="#1A1C23"/>
            <Setter Property="BorderBrush" Value="#22252D"/>
            <Setter Property="BorderThickness" Value="1,1,1,0"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6,6,0,0" Padding="20,10">
                            <ContentPresenter ContentSource="Header" x:Name="TabHeader"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#242731"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#323642"/>
                                <Setter Property="Foreground" Value="#C2C5CC"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#111218"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#2D72D9"/>
                                <Setter TargetName="TabBorder" Property="BorderThickness" Value="1,1,1,1"/>
                                <Setter Property="Foreground" Value="#2D72D9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- APP BODY -->
    <Border Background="#121212" CornerRadius="10" BorderBrush="#2D72D9" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="35"/> <!-- TITLE BAR -->
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="220"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- TITLE BAR -->
            <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#0A0B0E" MouseLeftButtonDown="TitleBar_MouseDown" CornerRadius="10,10,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="15,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="⚡" Foreground="#4D9EFF" FontSize="14" Margin="0,0,5,0"/>
                        <TextBlock Text="SystemOptimizer PRO" Foreground="#C8CBCF" FontSize="12" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Content="&#xE921;" Style="{StaticResource TitleBarButtonStyle}" Click="BtnMinimize_Click"/>
                        <Button Content="&#xE922;" Style="{StaticResource TitleBarButtonStyle}" Click="BtnMaximize_Click"/>
                        <Button Content="&#xE106;" Style="{StaticResource TitleBarCloseButtonStyle}" Click="BtnClose_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== SIDEBAR ===== -->
            <Border Grid.Row="1" Grid.RowSpan="3" Grid.Column="0"
                    Background="#0E0F13" BorderBrush="#1E2028" BorderThickness="0,0,1,0" CornerRadius="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Nav Items -->
                    <StackPanel Grid.Row="1" Margin="10,20,10,0">
                        <TextBlock Text="HAUPTMENÜ" Style="{StaticResource SectionHeader}" Margin="14,0,0,8"/>

                        <RadioButton IsChecked="True" Style="{StaticResource NavItemStyle}"
                                     Tag="🔄" Content="Update Center"
                                     x:Name="NavUpdates"/>
                        <RadioButton Style="{StaticResource NavItemStyle}"
                                     Tag="🛠️" Content="System-Reparatur"
                                     x:Name="NavRepair"/>
                        <RadioButton Style="{StaticResource NavItemStyle}"
                                     Tag="🧹" Content="Bereinigung &amp; Optimierung"
                                     x:Name="NavCleanup"/>
                        <RadioButton Style="{StaticResource NavItemStyle}"
                                     Tag="📦" Content="Software &amp; Apps"
                                     x:Name="NavSoftwareManager"/>
                        <RadioButton Style="{StaticResource NavItemStyle}"
                                     Tag="🚀" Content="System-Leistung"
                                     x:Name="NavPerformance"/>

                    </StackPanel>

                    <!-- Version Info -->
                    <StackPanel Grid.Row="2" Margin="20,0,20,20">
                        <Separator Background="#1E2028" Margin="0,0,0,12"/>
                        <TextBlock Text="v2.0 · .NET 10 · WPF" Foreground="#3A3D45" FontSize="10"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== MAIN CONTENT (Tab Pages) ===== -->
            <Grid Grid.Row="1" Grid.Column="1" Margin="30,25,30,15">

                <!-- Tab 1: Update Center -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChecked, ElementName=NavUpdates}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <StackPanel Grid.Row="0">
                            <TextBlock Text="Update Center" Foreground="White" FontSize="22" FontWeight="Light" Margin="0,0,0,4"/>
                            <TextBlock Text="Software- und Treiber-Updates — Deep-Scan über alle Scopes" Foreground="#4D9EFF" FontSize="12" Margin="0,0,0,22"/>
                        </StackPanel>

                        <!-- Side-by-Side Cards -->
                        <Grid Grid.Row="1" Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Software Updates Card -->
                            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0">
                                <StackPanel>
                                    <TextBlock Text="Software Updates (Stabil)" Style="{StaticResource CardTitle}"/>
                                    <TextBlock Style="{StaticResource CardDesc}" Height="45" TextWrapping="Wrap"
                                               Text="Deep-Scan über Machine-Scope, User-Scope und MS Store. Findet alle offiziellen stabilen Updates."/>
                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                        <Button Content="🔍  Updates suchen"    Command="{Binding CheckUpdatesCommand}"   Style="{StaticResource ModernButtonStyle}" FontSize="12" Padding="12,6" Width="140" Margin="0,0,8,0"/>
                                        <Button Content="⬇  Installieren" Command="{Binding InstallUpdatesCommand}" Style="{StaticResource ModernButtonStyle}" FontSize="12" Padding="12,6" Width="120" Margin="0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Hardware Drivers Card -->
                            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="0">
                                <StackPanel>
                                    <TextBlock Text="Hardware Treiber Updates" Style="{StaticResource CardTitle}"/>
                                    <TextBlock Style="{StaticResource CardDesc}" Height="45" TextWrapping="Wrap"
                                               Text="Deep-Scan über die offizielle Microsoft Update COM-API. Findet Pflicht- und optionale Hardware-Treiber."/>
                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                        <Button Content="🔍  Treiber suchen"    Command="{Binding CheckDriversCommand}"   Style="{StaticResource ModernButtonStyle}" FontSize="12" Padding="12,6" Width="140" Margin="0,0,8,0"/>
                                        <Button Content="⬇  Installieren" Command="{Binding InstallDriversCommand}" Style="{StaticResource ModernButtonStyle}" FontSize="12" Padding="12,6" Width="120" Margin="0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Updates DataGrid -->
                        <DataGrid Grid.Row="2" Style="{StaticResource PremiumDataGridStyle}"
                                  ItemsSource="{Binding UpdatesCollection}"
                                  FocusVisualStyle="{x:Null}"
                                  Margin="0,0,0,10"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  MaxHeight="450">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Update / Treiber Name" Binding="{Binding Name}" Width="*" />
                                <DataGridTextColumn Header="Typ" Binding="{Binding Type}" Width="160" />
                                <DataGridTextColumn Header="Aktuell" Binding="{Binding CurrentVersion}" Width="100" />
                                <DataGridTextColumn Header="Verfügbar" Binding="{Binding AvailableVersion}" Width="100" />
                                <DataGridTemplateColumn Header="Status" Width="130">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="{Binding Status}"/>
                                                        <Setter Property="Foreground" Value="#E2E2E2"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Erfolgreich">
                                                                <Setter Property="Foreground" Value="#4AF626"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Fehlgeschlagen">
                                                                <Setter Property="Foreground" Value="#FF3B30"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Wird installiert...">
                                                                <Setter Property="Foreground" Value="#4D9EFF"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Wird heruntergeladen...">
                                                                <Setter Property="Foreground" Value="#E5B3FF"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Pflicht-Treiber">
                                                                <Setter Property="Foreground" Value="#FFB3B3"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Optionaler Treiber">
                                                                <Setter Property="Foreground" Value="#FFCC00"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Ausstehend">
                                                                <Setter Property="Foreground" Value="#808590"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </ScrollViewer>

                <!-- Tab 2: System-Reparatur -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChecked, ElementName=NavRepair}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <StackPanel>
                        <TextBlock Text="System-Reparatur" Foreground="White" FontSize="22" FontWeight="Light" Margin="0,0,0,4"/>
                        <TextBlock Text="Tiefgreifende Reparatur des Windows Component Store und der Systemdateien" Foreground="#4D9EFF" FontSize="12" Margin="0,0,0,22"/>

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Windows Kernreparatur (DISM + SFC)" Style="{StaticResource CardTitle}"/>
                                <TextBlock Style="{StaticResource CardDesc}"
                                           Text="Führt zunächst DISM /RestoreHealth aus, um den Windows Component Store zu reparieren. Anschließend prüft SFC /scannow alle geschützten Systemdateien und stellt beschädigte Dateien wieder her."/>
                                <Button Content="🛠️  System tiefenprüfen" Command="{Binding RepairSystemCommand}" Style="{StaticResource ModernButtonStyle}" Width="200" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Tab 3: Bereinigung & Optimierung -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChecked, ElementName=NavCleanup}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <StackPanel>
                        <TextBlock Text="Bereinigung &amp; Optimierung" Foreground="White" FontSize="22" FontWeight="Light" Margin="0,0,0,4"/>
                        <TextBlock Text="Systemspeicher freigeben und Netzwerk-Overhead reduzieren" Foreground="#4D9EFF" FontSize="12" Margin="0,0,0,22"/>

                        <!-- Master Cleanup -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Master-Bereinigung" Style="{StaticResource CardTitle}"/>
                                <TextBlock Style="{StaticResource CardDesc}"
                                           Text="Löscht Temp-Dateien auf System-Partitionen, leert den Papierkorb (alle Laufwerke), entfernt DirectX-Shadercaches und Thumbnail-Caches, säubert Prefetch sowie Windows Update Überbleibsel und flusht den DNS-Cache."/>
                                <Button Content="🧹  System reinigen" Command="{Binding CleanupSystemCommand}" Style="{StaticResource ModernButtonStyle}" Width="175" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>

                        <!-- P2P Deaktivieren -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Netzwerk &amp; Latenz Optimieren" Style="{StaticResource CardTitle}"/>
                                <TextBlock Style="{StaticResource CardDesc}"
                                           Text="Deaktiviert bandbreitenfressende P2P-Windows-Updates an andere PCs (Delivery Optimization), um Ping zu reduzieren und Netzwerkressourcen zu schonen."/>
                                <Button Content="🌐  P2P-Downloads stoppen" Command="{Binding OptimizeNetworkCommand}" Style="{StaticResource ModernButtonStyle}" Width="210" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Tab 4: Software & Apps Manager -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChecked, ElementName=NavSoftwareManager}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Header -->
                        <RowDefinition Height="*"/>    <!-- TabControl with separate sub-views -->
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock Text="Software &amp; Apps" Foreground="White" FontSize="22" FontWeight="Light" Margin="0,0,0,4"/>
                        <TextBlock Text="Systemspezifische Programme &amp; Store Apps getrennt verwalten, live filtern und tiefenreinigen" Foreground="#4D9EFF" FontSize="12"/>
                    </StackPanel>

                    <!-- Modern WPF TabControl for separating Classic vs Store Apps -->
                    <TabControl Grid.Row="1" Style="{StaticResource PremiumTabControlStyle}">
                        
                        <!-- Reiter 1: System-Programme (Klassische Desktop-Software) -->
                        <TabItem Header="System-Programme" Style="{StaticResource PremiumTabItemStyle}">
                            <Grid Margin="0,15,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/> <!-- Search bar -->
                                    <RowDefinition Height="*"/>    <!-- DataGrid -->
                                    <RowDefinition Height="Auto"/> <!-- Controls -->
                                </Grid.RowDefinitions>

                                <!-- Search Bar -->
                                <Grid Grid.Row="0" Margin="0,0,0,15">
                                    <TextBox Style="{StaticResource ModernTextBoxStyle}" 
                                             Tag="Nach Name filtern..."
                                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Height="38" VerticalContentAlignment="Center"/>
                                    <TextBlock Text="🔍" Foreground="#555A67" FontSize="14" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,15,0" IsHitTestVisible="False"/>
                                </Grid>

                                <!-- DataGrid -->
                                <DataGrid Grid.Row="1" Style="{StaticResource PremiumDataGridStyle}"
                                          ItemsSource="{Binding FilteredSoftware}"
                                          Margin="0,0,0,15" FocusVisualStyle="{x:Null}">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Width="40" CanUserResize="False">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" 
                                                              HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                              Style="{StaticResource PremiumCheckBoxStyle}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Programmname" Binding="{Binding Name}" Width="*" />
                                        <DataGridTextColumn Header="Version" Binding="{Binding DisplayVersion}" Width="140" />
                                        <DataGridTextColumn Header="Herausgeber" Binding="{Binding Publisher}" Width="200" />
                                        <DataGridTextColumn Header="Größe" Binding="{Binding EstimatedSize}" Width="110" />
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- Controls -->
                                <Border Grid.Row="2" Background="#1A1C23" BorderBrush="#22252D" BorderThickness="1" CornerRadius="8" Padding="15,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <CheckBox Grid.Column="0" Content="Restliche Dateien und leere Ordner automatisch löschen" 
                                                  IsChecked="{Binding CleanLeftovers}"
                                                  Style="{StaticResource PremiumCheckBoxStyle}" />
                                        
                                        <Button Grid.Column="1" Content="🗑  Deinstallieren" 
                                                Command="{Binding UninstallCommand}" 
                                                Style="{StaticResource ModernButtonStyle}" 
                                                Width="160" Height="36" Margin="10,0,0,0" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </TabItem>

                        <!-- Reiter 2: Windows Apps (Microsoft Store / UWP Apps) -->
                        <TabItem Header="Windows Apps" Style="{StaticResource PremiumTabItemStyle}">
                            <Grid Margin="0,15,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/> <!-- Search bar -->
                                    <RowDefinition Height="*"/>    <!-- DataGrid -->
                                    <RowDefinition Height="Auto"/> <!-- Controls -->
                                </Grid.RowDefinitions>

                                <!-- Search Bar -->
                                <Grid Grid.Row="0" Margin="0,0,0,15">
                                    <TextBox Style="{StaticResource ModernTextBoxStyle}" 
                                             Tag="Nach Name filtern..."
                                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Height="38" VerticalContentAlignment="Center"/>
                                    <TextBlock Text="🔍" Foreground="#555A67" FontSize="14" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,15,0" IsHitTestVisible="False"/>
                                </Grid>

                                <!-- DataGrid -->
                                <DataGrid Grid.Row="1" Style="{StaticResource PremiumDataGridStyle}"
                                          ItemsSource="{Binding FilteredUwpApps}"
                                          Margin="0,0,0,15" FocusVisualStyle="{x:Null}">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Width="40" CanUserResize="False">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" 
                                                              HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                              Style="{StaticResource PremiumCheckBoxStyle}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Programmname" Binding="{Binding Name}" Width="*" />
                                        <DataGridTextColumn Header="Version" Binding="{Binding DisplayVersion}" Width="140" />
                                        <DataGridTextColumn Header="Herausgeber" Binding="{Binding Publisher}" Width="200" />
                                        <DataGridTextColumn Header="Größe" Binding="{Binding EstimatedSize}" Width="110" />
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- Controls -->
                                <Border Grid.Row="2" Background="#1A1C23" BorderBrush="#22252D" BorderThickness="1" CornerRadius="8" Padding="15,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <CheckBox Grid.Column="0" Content="Restliche Dateien und leere Ordner automatisch löschen" 
                                                  IsChecked="{Binding CleanLeftovers}"
                                                  Style="{StaticResource PremiumCheckBoxStyle}" />
                                        
                                        <Button Grid.Column="1" Content="🗑  Deinstallieren" 
                                                Command="{Binding UninstallCommand}" 
                                                Style="{StaticResource ModernButtonStyle}" 
                                                Width="160" Height="36" Margin="10,0,0,0" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Grid>

                <!-- Tab 5: System-Leistung -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChecked, ElementName=NavPerformance}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Header -->
                        <RowDefinition Height="Auto"/> <!-- RAM Card -->
                        <RowDefinition Height="*"/>    <!-- Autostart Card/Grid -->
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock Text="System-Leistung" Foreground="White" FontSize="22" FontWeight="Light" Margin="0,0,0,4"/>
                        <TextBlock Text="Arbeitsspeicher sicher optimieren und Autostart-Programme kontrollieren" Foreground="#4D9EFF" FontSize="12"/>
                    </StackPanel>

                    <!-- RAM Card -->
                    <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Arbeitsspeicher-Booster" Style="{StaticResource CardTitle}"/>
                                <TextBlock Style="{StaticResource CardDesc}"
                                           Text="Bereinigt ungenutzten RAM aller laufenden Prozesse über das native Windows API EmptyWorkingSet, ohne gestartete Applikationen zu beenden oder zu stören."/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="⚡ RAM-Speicher optimieren" 
                                    Command="{Binding BoostRamCommand}" 
                                    Style="{StaticResource ModernButtonStyle}" 
                                    Width="220" Height="40" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Autostart Card -->
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Search bar -->
                            <RowDefinition Height="*"/>    <!-- DataGrid -->
                        </Grid.RowDefinitions>

                        <!-- Search Bar -->
                        <Grid Grid.Row="0" Margin="0,0,0,15">
                            <TextBox Style="{StaticResource ModernTextBoxStyle}" 
                                     Tag="Autostart durchsuchen..."
                                     Text="{Binding StartupSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Height="38" VerticalContentAlignment="Center"/>
                            <TextBlock Text="🔍" Foreground="#555A67" FontSize="14" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,15,0" IsHitTestVisible="False"/>
                        </Grid>

                        <!-- DataGrid -->
                        <DataGrid Grid.Row="1" Style="{StaticResource PremiumDataGridStyle}"
                                  ItemsSource="{Binding FilteredStartupItems}"
                                  Margin="0,0,0,15" FocusVisualStyle="{x:Null}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Programmname" Binding="{Binding Name}" Width="180" />
                                <DataGridTextColumn Header="Start-Pfad" Binding="{Binding Path}" Width="*" />
                                <DataGridTextColumn Header="Bereich" Binding="{Binding RegistryKeyPath}" Width="90" />
                                <DataGridTemplateColumn Header="Status" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Aktiviert"/>
                                                        <Setter Property="Foreground" Value="#4AF626"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                <Setter Property="Text" Value="Deaktiviert"/>
                                                                <Setter Property="Foreground" Value="#FF3B30"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Aktion" Width="130">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.ToggleStartupCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                    CommandParameter="{Binding}"
                                                    Height="26" Padding="8,2" Margin="0" FontSize="11">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
                                                        <Setter Property="Content" Value="Deaktivieren"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                <Setter Property="Content" Value="Aktivieren"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>


            </Grid>

            <!-- ===== STATUS BAR ===== -->
            <Grid Grid.Row="2" Grid.Column="1" Margin="30,0,30,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#4D9EFF" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5"/>
                    <ProgressBar IsIndeterminate="{Binding IsBusy}">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar" BasedOn="{StaticResource PremiumProgressBarStyle}">
                                <Setter Property="Opacity" Value="0"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.3"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.3"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>
                </StackPanel>

                <Button Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center"
                        Content="✕  ABBRECHEN" Command="{Binding CancelCommand}" Width="130" Height="34">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource DangerButtonStyle}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- ===== LIVE CONSOLE ===== -->
            <Border Grid.Row="3" Grid.Column="1" Margin="30,0,30,20"
                    Background="#050505" BorderBrush="#007ACC" BorderThickness="1.5" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect Color="#007ACC" BlurRadius="8" Opacity="0.35" ShadowDepth="0"/>
                </Border.Effect>
                <Grid>
                    <!-- Classic Console Container (Visible for other tabs) -->
                    <Grid x:Name="ClassicConsoleContainer">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsChecked, ElementName=NavUpdates}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border Grid.Row="0" Background="#0C1014" CornerRadius="8,8,0,0" Padding="15,7" BorderBrush="#1C2025" BorderThickness="0,0,0,1">
                            <Grid>
                                <TextBlock Text="▶  LIVE EXECUTION CONSOLE  //  SYSTEM.OVERRIDE"
                                           Foreground="#2D72D9" FontSize="10" FontFamily="Consolas" FontWeight="Bold" VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBlock Text="GESCHWINDIGKEIT: " Foreground="#555A67" FontSize="9" FontFamily="Consolas" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding LiveScanSpeed}" Foreground="#00FFCC" FontSize="9" FontFamily="Consolas" FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Body (Full-width Text Terminal for classic view) -->
                        <TextBox Grid.Row="1" x:Name="TxtLog"
                                 Text="{Binding LogText, Mode=OneWay}"
                                 IsReadOnly="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Background="Transparent" Foreground="#4AF626"
                                 FontFamily="Consolas" FontSize="11" FontWeight="Medium"
                                 Margin="12,8,12,8" BorderThickness="0"
                                 TextChanged="TxtLog_TextChanged"/>
                    </Grid>



                    <!-- Modern Update Dashboard (Visible only when Updates is active) -->
                    <Border x:Name="ModernUpdateDashboard" Padding="25,15"
                            UseLayoutRounding="True" SnapsToDevicePixels="True" TextOptions.TextFormattingMode="Display">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsChecked, ElementName=NavUpdates}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <TextBlock Text="MONITOR // SYSTEM.UPDATE.STATUS"
                                           Foreground="#4D9EFF" FontSize="11" FontFamily="Consolas" FontWeight="Bold"/>
                            </Grid>

                            <UniformGrid Grid.Row="1" Columns="3" Rows="1" VerticalAlignment="Center" Margin="0,5">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="📦 SOFTWARE-UPDATES" Foreground="#808590" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding UpdatesFoundCount}" Foreground="#4D9EFF" FontSize="26" FontFamily="Consolas" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>

                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="🔌 SYSTEM-TREIBER" Foreground="#808590" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding DriversFoundCount}" Foreground="#4AF626" FontSize="26" FontFamily="Consolas" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>

                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="⚡ STATUS DER OPERATION" Foreground="#808590" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding CurrentUpdateActivity}" Foreground="#FFFFFF" FontSize="12" FontFamily="Consolas" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,6,0,0" TextWrapping="Wrap" MaxWidth="250" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </UniformGrid>

                            <StackPanel Grid.Row="2" Margin="0,10,0,0">
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="WINDOWS UPDATE &amp; WINGET SYNCHRONISATION" Foreground="#555A67" FontSize="9" FontWeight="Bold" HorizontalAlignment="Left"/>
                                    <TextBlock Text="SUCHE / INSTALLATION LÄUFT..." Foreground="#4D9EFF" FontSize="9" FontWeight="Bold" HorizontalAlignment="Right">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                <ProgressBar Height="6" IsIndeterminate="{Binding IsBusy}" Style="{StaticResource PremiumProgressBarStyle}">
                                    <ProgressBar.Effect>
                                        <DropShadowEffect Color="#4D9EFF" BlurRadius="6" ShadowDepth="0" Opacity="0.7"/>
                                    </ProgressBar.Effect>
                                </ProgressBar>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
