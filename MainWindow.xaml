<Window 
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="System Optimierer PRO" Style="{StaticResource ModernWindowStyle}">

    <!-- Modern Recovery Dashboard -->
    <TabControl>
        <TabItem Header="Recovery Center">
            <Grid>
                <!-- File Type Counters -->
                <StackPanel Orientation="Horizontal">
                    <Border Style="{StaticResource CounterTile}">
                        <TextBlock Text="{Binding DocCount}" Style="{StaticResource CounterValue}"/>
                        <TextBlock Text="Documents" Style="{StaticResource CounterLabel}"/>
                    </Border>
                    <!-- [other counters...] -->
                </StackPanel>

                <!-- Scan Progress -->
                <ProgressBar Style="{StaticResource PremiumProgressBarStyle}" 
                             Value="{Binding ScanProgress}"/>
                
                <!-- Results Grid -->
                <DataGrid ItemsSource="{Binding RecoverableFiles}" 
                          Style="{StaticResource ModernDataGridStyle}">
                    <!-- [columns definition...] -->
                </DataGrid>
            </Grid>
        </TabItem>

        <!-- Modern Update Center -->
        <TabItem Header="Update Center">
            <DataGrid ItemsSource="{Binding Updates}" 
                      Style="{StaticResource ModernDataGridStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Component" Binding="{Binding Name}" Width="3*"/>
                    <DataGridTextColumn Header="Current" Binding="{Binding CurrentVersion}" Width="1*"/>
                    <DataGridTextColumn Header="Available" Binding="{Binding AvailableVersion}" Width="1*"/>
                    <DataGridTemplateColumn Header="Action" Width="1*">
                        <!-- [action buttons...] -->
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </TabItem>
    </TabControl>
</Window>